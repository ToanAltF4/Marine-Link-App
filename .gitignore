# ─── MarineLink Monorepo .gitignore ───────────────────────────────────────────
# This file covers the repository root.
# Frontend-specific ignores also live in frontend/.gitignore
# Backend-specific ignores also live in backend/.gitignore

# ── Flutter / Dart (root-level artifacts from before monorepo split) ──────────
.dart_tool/
.packages
.flutter-plugins
.flutter-plugins-dependencies
pubspec.lock        # root-level lock (not part of any subproject)
build/              # Flutter build output at root
*.dart.js
*.info.json
*.js_
*.js.deps
*.js.map
doc/api/

# ── Spring Boot / Maven ───────────────────────────────────────────────────────
target/

# ── Secrets — NEVER commit ───────────────────────────────────────────────────
.env
.env.*
*.env
application-local.yml
application-prod.yml
application-secrets.yml

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ── IntelliJ / Android Studio ────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/

# ── Coverage raw output (keep reports, not raw exec files) ───────────────────
*.exec
jacoco.exec
lcov.info
coverage/
